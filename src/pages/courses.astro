---
import BaseLayout from '../layouts/BaseLayout.astro';
import COURSES, { LEVEL_LABELS, LEVEL_COLORS } from '../data/courses';

const pageTitle = 'Khóa Học';
const pageDescription = 'Các khóa học móc len handmade từ cơ bản đến nâng cao. Học trực tiếp qua Google Meet với giảng viên giàu kinh nghiệm.';

const faqs = [
  {
    q: 'Tôi không biết gì về móc len, có học được không?',
    a: 'Hoàn toàn được. Khóa học dành cho cả người mới bắt đầu, hướng dẫn từng bước từ cơ bản đến hoàn thiện sản phẩm.',
  },
  {
    q: 'Học qua Google Meet thì như thế nào?',
    a: 'Bạn sẽ nhận bài học và được hỗ trợ trực tiếp qua Google Meet. Có thể gửi hình ảnh sản phẩm để được hướng dẫn khi gặp khó khăn.',
  },
  {
    q: 'Tôi có thể học lại nếu chưa hiểu không?',
    a: 'Có. Bạn có thể xem lại nội dung và hỏi bất cứ lúc nào khi cần hỗ trợ thêm.',
  },
  {
    q: 'Thanh toán như thế nào?',
    a: 'Bạn chỉ cần chuyển khoản theo thông tin được cung cấp. Sau khi xác nhận thanh toán, bạn sẽ được hướng dẫn tham gia khóa học.',
  },
];

const cardBgColors = ['#CFECF3', '#DAF9DE', '#F9F0F5', '#F0F9F1'];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- PAGE HERO BAND -->
  <section class="relative py-[80px] md:py-[120px] overflow-hidden" style="background: linear-gradient(135deg, #F6FFDC 0%, #DAF9DE 50%, #CFECF3 100%);">
    <!-- Decorative elements -->
    <div class="absolute top-10 right-10 w-40 h-40 rounded-full opacity-40" style="background: radial-gradient(circle, #F9B2D7 0%, transparent 70%);"></div>
    <div class="absolute bottom-10 left-10 w-56 h-56 rounded-full opacity-30" style="background: radial-gradient(circle, #D4869E 0%, transparent 70%);"></div>
    <div class="absolute top-1/3 left-1/4 w-24 h-24 rounded-full opacity-25" style="background: radial-gradient(circle, #CFECF3 0%, transparent 70%);"></div>
    <div class="absolute bottom-1/4 right-1/4 w-32 h-32 rounded-full opacity-30" style="background: radial-gradient(circle, #DAF9DE 0%, transparent 70%);"></div>

    <div class="container-base relative z-10">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6" style="background: #D4869E; box-shadow: 0 4px 15px rgba(212,134,158,0.3);">
          <span class="block w-2 h-2 rounded-full" style="background: white;"></span>
          <span class="font-body text-sm font-semibold tracking-wider uppercase text-white">Học cùng chúng tôi</span>
        </div>

        <h1 class="font-heading font-[500] leading-[1.2]" style="font-size: clamp(2.2rem, 4.5vw, 3.5rem); color: #2C3E3F; font-style: italic; letter-spacing: -0.02em;">
          Khóa học móc len
        </h1>
        <p class="font-body text-[1.1rem] font-medium leading-relaxed mt-5 max-w-xl mx-auto" style="color: #3D7A7F;">
          Từ người mới bắt đầu đến kỹ thuật nâng cao — chúng tôi đồng hành cùng bạn trong từng mũi móc.
        </p>

        <!-- Trust Indicators -->
        <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4 mt-10">
          <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.5);">
            <svg class="w-5 h-5 flex-shrink-0" style="color: #D4869E;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <span class="font-body text-sm font-medium" style="color: #2C3E3F;">Học qua Google Meet</span>
          </div>
          <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.5);">
            <svg class="w-5 h-5 flex-shrink-0" style="color: #3D7A7F;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            <span class="font-body text-sm font-medium" style="color: #2C3E3F;">Hỗ trợ sau khóa học</span>
          </div>
          <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.5);">
            <svg class="w-5 h-5 flex-shrink-0" style="color: #6B8A8C;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
            <span class="font-body text-sm font-medium" style="color: #2C3E3F;">Tài liệu PDF đính kèm</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS SECTION -->
  <section class="py-[80px]" style="background-color: #FAFAF8;">
    <div class="container-base">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background: #CFECF3; box-shadow: 0 4px 15px rgba(61,122,127,0.2);">
          <span class="block w-2 h-2 rounded-full" style="background: #3D7A7F;"></span>
          <span class="font-body text-sm font-semibold tracking-wider uppercase" style="color: #3D7A7F;">Quy trình</span>
        </div>
        <h2 class="font-heading font-[500] leading-[1.2]" style="font-size: clamp(1.6rem, 2.8vw, 2.2rem); margin-top: 8px; color: #2C3E3F; font-style: italic; letter-spacing: -0.02em;">
          Đăng ký học như thế nào?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mt-12 max-w-4xl mx-auto">
        <!-- Step 1 -->
        <div class="text-center p-[30px] rounded-2xl transition-all duration-300 hover:-translate-y-2 hover:shadow-xl" style="background: white; box-shadow: 0 4px 24px rgba(0,0,0,0.06);">
          <div class="w-14 h-14 mx-auto rounded-full flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #CFECF3 0%, #DAF9DE 100%); box-shadow: 0 4px 15px rgba(61,122,127,0.2);">
            <span class="font-heading font-[500] text-lg" style="color: #2C3E3F;">01</span>
          </div>
          <h3 class="font-heading font-[500] text-lg" style="color: #2C3E3F; font-style: italic;">Chọn khóa học</h3>
          <p class="font-body text-[0.95rem] font-medium leading-[1.7] mt-2" style="color: #6B8A8C;">
            Xem mô tả và chọn khóa phù hợp với trình độ của bạn.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="text-center p-[30px] rounded-2xl transition-all duration-300 hover:-translate-y-2 hover:shadow-xl" style="background: white; box-shadow: 0 4px 24px rgba(0,0,0,0.06);">
          <div class="w-14 h-14 mx-auto rounded-full flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #F9B2D7 0%, #D4869E 100%); box-shadow: 0 4px 15px rgba(212,134,158,0.3);">
            <span class="font-heading font-[500] text-lg text-white">02</span>
          </div>
          <h3 class="font-heading font-[500] text-lg" style="color: #2C3E3F; font-style: italic;">Liên hệ đăng ký</h3>
          <p class="font-body text-[0.95rem] font-medium leading-[1.7] mt-2" style="color: #6B8A8C;">
            Liên hệ với chúng tôi để đặt lịch và thanh toán.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="text-center p-[30px] rounded-2xl transition-all duration-300 hover:-translate-y-2 hover:shadow-xl" style="background: white; box-shadow: 0 4px 24px rgba(0,0,0,0.06);">
          <div class="w-14 h-14 mx-auto rounded-full flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #DAF9DE 0%, #CFECF3 100%); box-shadow: 0 4px 15px rgba(61,122,127,0.2);">
            <span class="font-heading font-[500] text-lg" style="color: #2C3E3F;">03</span>
          </div>
          <h3 class="font-heading font-[500] text-lg" style="color: #2C3E3F; font-style: italic;">Bắt đầu học</h3>
          <p class="font-body text-[0.95rem] font-medium leading-[1.7] mt-2" style="color: #6B8A8C;">
            Nhận tài liệu và học theo lịch đã hẹn. Hỗ trợ 24/7 trong quá trình học.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- COURSE GRID -->
  <section class="py-[80px]" style="background: linear-gradient(180deg, #F6FFDC 0%, #FAFAF8 100%);">
    <div class="container-base">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background: #CFECF3; box-shadow: 0 4px 15px rgba(61,122,127,0.2);">
          <span class="block w-2 h-2 rounded-full" style="background: #3D7A7F;"></span>
          <span class="font-body text-sm font-semibold tracking-wider uppercase" style="color: #3D7A7F;">Các khóa học</span>
        </div>
        <h2 class="font-heading font-[500] leading-[1.2]" style="font-size: clamp(1.6rem, 2.8vw, 2.2rem); margin-top: 8px; color: #2C3E3F; font-style: italic; letter-spacing: -0.02em;">
          Chọn lộ trình phù hợp với bạn.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12 max-w-4xl mx-auto">
        {COURSES.map((course, index) => (
          <article class="rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl group" style="background: white; box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
            <!-- Colored Header -->
            <div class="px-6 pt-6 pb-5" style={`background: linear-gradient(135deg, ${cardBgColors[index] || '#DAF9DE'} 0%, ${cardBgColors[(index + 1) % cardBgColors.length] || '#CFECF3'} 100%); border-radius: 16px 16px 0 0;`}>
              <span
                class="inline-block font-body text-[0.78rem] uppercase tracking-[0.14em] px-4 py-2 font-extrabold rounded-full"
                style={`background-color: ${LEVEL_COLORS[course.level]}; color: #ffffff; box-shadow: 0 4px 14px rgba(0,0,0,0.25); border: 2px solid rgba(255,255,255,0.6);`}
              >
                {LEVEL_LABELS[course.level]}
              </span>
            </div>

            <!-- Content -->
            <div class="p-6 text-center">
              <h3 class="font-heading font-[500] text-2xl" style="color: #2C3E3F; font-style: italic;">
                {course.title}
              </h3>
              <p class="font-body text-base font-medium leading-[1.7] mt-3" style="color: #4A6B6E;">
                {course.description}
              </p>
              <div class="mt-5">
                <a
                  href="#"
                  class="inline-flex items-center px-6 py-2.5 rounded-full font-body text-base font-semibold transition-all duration-300 hover:scale-105"
                  style="background: linear-gradient(135deg, #CFECF3 0%, #DAF9DE 100%); color: #2C3E3F; box-shadow: 0 2px 10px rgba(61,122,127,0.15);"
                >
                  Học qua Google Meet
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section style="background: linear-gradient(180deg, #FFFFFF 0%, #FFF5F8 100%); padding: 80px 24px;">
    <!-- Decorative background -->
    <div class="absolute left-0 top-1/2 w-32 h-32 rounded-full opacity-20" style="background: radial-gradient(circle, #E8487A 0%, transparent 70%); transform: translateY(-50%);"></div>
    <div class="absolute right-0 top-1/3 w-40 h-40 rounded-full opacity-15" style="background: radial-gradient(circle, #3D7A7F 0%, transparent 70%);"></div>
    
    <!-- Header -->
    <div style="display: flex; flex-direction: column; align-items: center; text-align: center; width: 100%; margin-bottom: 48px;">
      <!-- Cute pill badge -->
      <div class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full mb-8" style="background: linear-gradient(135deg, #F6FFDC 0%, #DAF9DE 100%); box-shadow: 0 4px 20px rgba(212,134,158,0.25);">
        <span class="block w-2.5 h-2.5 rounded-full" style="background: #E8487A;"></span>
        <span class="font-body text-base font-bold tracking-wider uppercase" style="color: #2C3E3F;">Câu hỏi thường gặp</span>
        <span class="block w-2.5 h-2.5 rounded-full" style="background: #E8487A;"></span>
      </div>
      
      <!-- Stylized heading -->
      <h2 class="font-heading font-[500] leading-[1.2] m-0" style="font-size: clamp(2rem, 4vw, 2.8rem); font-style: italic; letter-spacing: -0.02em;">
        <span style="background: linear-gradient(135deg, #E8487A 0%, #D4869E 50%, #3D7A7F 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Bạn muốn biết thêm?
        </span>
      </h2>
      
      <!-- Decorative line -->
      <div class="flex items-center justify-center gap-4 mt-6" style="margin: 24px auto 0;">
        <div class="h-[2px] w-16 rounded-full" style="background: linear-gradient(90deg, transparent, #E8487A);"></div>
        <span style="color: #D4869E; font-size: 1.1rem;">♥</span>
        <div class="h-[2px] w-16 rounded-full" style="background: linear-gradient(90deg, #3D7A7F, transparent);"></div>
      </div>
    </div>

    <!-- FAQ Items -->
    <div style="width: 100%; max-width: 640px; margin: 0 auto;">
      {faqs.map((faq, index) => (
        <div class="faq-item mb-4 rounded-2xl overflow-hidden" style="background: white; box-shadow: 0 4px 20px rgba(0,0,0,0.06); border: 1px solid rgba(0,0,0,0.04);">
          <button
            class="faq-trigger w-full text-left flex justify-between items-center p-5 md:p-6 cursor-pointer bg-transparent border-none"
            data-faq-trigger={index}
            aria-expanded="false"
          >
            <span class="font-heading font-[500] pr-4" style="font-size: 1.1rem; color: #2C3E3F;">
              {faq.q}
            </span>
            <span class="faq-indicator font-body flex-shrink-0 w-9 h-9 flex items-center justify-center rounded-full transition-all duration-300 text-lg" style="background: linear-gradient(135deg, #F6FFDC 0%, #CFECF3 100%); color: #E8487A; box-shadow: 0 2px 8px rgba(232,72,122,0.2);">
              +
            </span>
          </button>
          <div
            class="faq-content overflow-hidden"
            data-faq-content={index}
            style="max-height: 0; transition: max-height 300ms ease;"
          >
            <p class="font-body text-base font-light leading-[1.9]" style="color: #5A7A7D; padding: 0 24px 20px;">
              {faq.a}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const faqTriggers = document.querySelectorAll('.faq-trigger');
  const faqContents = document.querySelectorAll('.faq-content');

  faqTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const index = trigger.getAttribute('data-faq-trigger');
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

      // Close all other FAQs
      faqTriggers.forEach((t) => {
        t.setAttribute('aria-expanded', 'false');
        const tIndex = t.getAttribute('data-faq-trigger');
        const content = document.querySelector(`[data-faq-content="${tIndex}"]`);
        const indicator = t.querySelector('.faq-indicator');
        if (content) (content as HTMLElement).style.maxHeight = '0';
        if (indicator) indicator.textContent = '+';
      });

      // Toggle current FAQ
      if (!isExpanded && index !== null) {
        const content = document.querySelector(`[data-faq-content="${index}"]`);
        const indicator = trigger.querySelector('.faq-indicator');

        trigger.setAttribute('aria-expanded', 'true');
        if (content) (content as HTMLElement).style.maxHeight = '250px';
        if (indicator) indicator.textContent = '−';
      }
    });
  });
</script>
