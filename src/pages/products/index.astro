---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'Sản Phẩm';
const pageDescription = 'Khám phá các sản phẩm len handmade của Tiệm Len Nhà Dev — hoa len, bó hoa, phụ kiện và nhiều hơn nữa.';

const categories = [
  { value: 'all', label: 'Tất Cả Sản Phẩm', emoji: '✨' },
  { value: 'hoa-le', label: 'Hoa Len', emoji: '🌸' },
  { value: 'phu-kien', label: 'Thú Len - Móc Khóa', emoji: '🎀' },
  { value: 'bo-hoa', label: 'Bó Hoa Len - Giỏ Hoa', emoji: '💐' },
];

const products = [
  {
    id: 'sp-001',
    name: 'Hoa Hướng Dương Len',
    category: 'hoa-le',
    image: '/tiemlennhadev/images/hoa-huonghuong1.jpg',
    description: 'Hoa hướng dương len handmade, màu vàng tươi sáng. Không héo, không cần tưới nước.',
    badge: 'Bán chạy',
    color: '#F9B2D7',
  },
  {
    id: 'sp-002',
    name: 'Hoa Mẫu Đơn Len',
    category: 'hoa-le',
    image: '/tiemlennhadev/images/anh-bia.png',
    description: 'Hoa mẫu đơn len handmade đẹp mắt, thích hợp trang trí hoặc làm quà tặng.',
    badge: 'Bán Chạy',
    color: '#CFECF3',
  },
  {
    id: 'sp-003',
    name: 'Tulip Cánh Bèo',
    category: 'hoa-le',
    image: '/tiemlennhadev/images/hoa-tulip.jpg',
    description: 'Hoa tulip với cánh hoa 3D độc đáo, mang lại vẻ đẹp tinh tế cho không gian của bạn.',
    badge: 'Mới',
    color: '#DAF9DE',
  },
  {
    id: 'sp-004',
    name: 'Bó Hoa Len Hỗn Hợp',
    category: 'bo-hoa',
    image: '/tiemlennhadev/images/Hoa-HonHop2.jpg',
    description: 'Bó hoa gồm nhiều loại hoa len kết hợp hài hòa, đóng gói quà tặng sang trọng.',
    badge: 'Phổ biến',
    color: '#F6FFDC',
  },
  {
    id: 'sp-005',
    name: 'Bó Hoa Hồng Len',
    category: 'bo-hoa',
    image: '/tiemlennhadev/images/hoa-hong-1.jpg',
    description: 'Bó hoa hồng len đôi lãng mạn, hoàn hảo cho dịp kỷ niệm và tặng quà.',
    badge: 'Bán Chạy',
    color: '#F9B2D7',
  },
  {
    id: 'sp-006',
    name: 'Móc Khóa Mèo Nhung Gấu',
    category: 'phu-kien',
    image: '/tiemlennhadev/images/meo-ngotngao1.jpg',
    description: 'Móc khóa hình gấu bông len mềm mại, nhỏ gọn xinh xắn. Đáng yêu và dễ thương.',
    badge: '',
    color: '#CFECF3',
  },
  {
    id: 'sp-007',
    name: 'Móc Khóa 5 Cánh Dây Tây',
    category: 'phu-kien',
    image: '/tiemlennhadev/images/moc-5canhdaytay.jpg',
    description: 'Thỏ tai dài móc len đáng iu, có nhiều màu để bạn lựa chọn theo sở thích.',
    badge: 'Mới',
    color: '#DAF9DE',
  },
  {
    id: 'sp-008',
    name: 'Hoa Hỗn Hợp',
    category: 'bo-hoa',
    image: '/tiemlennhadev/images/hoahonhop.jpg',
    description: 'Bộ set gồm nhiều loại hoa len mini, thích hợp làm phụ kiện trang trí.',
    badge: '',
    color: '#F6FFDC',
  },
  {
    id: 'sp-009',
    name: 'Móc Khóa 5 Cánh',
    category: 'phu-kien',
    image: '/tiemlennhadev/images/Phukien-khoa5canh.jpg',
    description: 'Móc khóa len 5 cánh độc đáo, nhiều màu sắc.',
    badge: '',
    color: '#F9B2D7',
  },
  {
    id: 'sp-010',
    name: 'Móc Khóa Trái Tym',
    category: 'phu-kien',
    image: '/tiemlennhadev/images/moc-traitym.jpg',
    description: 'Móc khóa hình trái tim tym dễ thương, màu hồng đáng yêu.',
    badge: '',
    color: '#CFECF3',
  },
  {
    id: 'sp-011',
    name: 'Móc Khóa Ếch và Vịt',
    category: 'phu-kien',
    image: '/tiemlennhadev/images/moc-khoa-vit1.jpg',
    description: 'Bộ móc khóa ếch và vịt cute, thích hợp làm quà.',
    badge: '',
    color: '#DAF9DE',
  },
  {
    id: 'sp-012',
    name: 'Móc Khóa Thỏ Miffy',
    category: 'phu-kien',
    image: '/tiemlennhadev/images/tho-miffy.jpg',
    description: 'Móc khóa thỏ miffy xinh xắn, phong cách Nhật Bản.',
    badge: '',
    color: '#F6FFDC',
  },
];

const bgColors = ['#F9B2D7', '#CFECF3', '#DAF9DE', '#F6FFDC'];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- PAGE HERO SECTION -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #F9B2D7 0%, #CFECF3 50%, #DAF9DE 100%); min-height: 35vh; width: 100%;">
    <div class="absolute inset-0 flex items-center">
      <!-- Left decorative -->
      <div class="absolute left-0 top-1/2 -translate-y-1/2 w-72 h-72 rounded-full opacity-20" style="background: radial-gradient(circle, white 0%, transparent 70%);"></div>
      <div class="absolute left-20 top-1/4 w-32 h-32 rounded-full opacity-15" style="background: radial-gradient(circle, #F9B2D7 0%, transparent 70%);"></div>
      
      <!-- Right decorative -->
      <div class="absolute right-0 top-1/2 -translate-y-1/2 w-80 h-80 rounded-full opacity-25" style="background: radial-gradient(circle, white 0%, transparent 70%);"></div>
      <div class="absolute right-32 bottom-1/4 w-40 h-40 rounded-full opacity-15" style="background: radial-gradient(circle, #DAF9DE 0%, transparent 70%);"></div>
    </div>

    <div class="container-base relative z-10 py-12 md:py-16">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full mb-6" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); box-shadow: 0 4px 20px rgba(249,178,215,0.3);">
          <span class="w-2.5 h-2.5 rounded-full" style="background: #E8487A;"></span>
          <span class="font-body text-sm font-semibold tracking-wider uppercase" style="color: #2C3E3F;">Cửa hàng</span>
        </div>

        <!-- Title -->
        <h1 class="font-heading font-[500] leading-[1.15]" style="font-size: clamp(2.2rem, 5vw, 3.5rem); color: #2C3E3F; font-style: italic; letter-spacing: -0.02em;">
          Sản Phẩm Len Handmade
        </h1>

        <!-- Decorative line -->
        <div class="flex items-center justify-center gap-4 my-6">
          <div class="w-16 h-px" style="background: linear-gradient(90deg, transparent, #E8487A, transparent);"></div>
          <span class="text-2xl">🌸</span>
          <div class="w-16 h-px" style="background: linear-gradient(90deg, transparent, #E8487A, transparent);"></div>
        </div>

        <!-- Subtitle -->
        <p class="font-body text-lg font-medium leading-relaxed" style="color: #4A6B6E; max-width: 600px; margin: 0 auto;">
          Mỗi sản phẩm đều được làm thủ công với tình yêu
        </p>
      </div>
    </div>
  </section>

  <!-- CATEGORY FILTER SECTION -->
  <section class="sticky top-[72px] z-50 py-5" style="background: linear-gradient(180deg, white 0%, rgba(255,255,255,0.95) 100%); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0,0,0,0.05);">
    <div class="filter-container">
      <div class="flex flex-wrap items-center justify-center gap-3">
        {categories.map((cat, index) => (
          <button
            class="category-btn px-5 py-2.5 rounded-full font-body text-sm font-medium transition-all duration-300"
            data-category={cat.value}
            style={cat.value === 'all' ? 'background: linear-gradient(135deg, #F9B2D7 0%, #E8487A 100%); color: white; box-shadow: 0 4px 15px rgba(249,178,215,0.4);' : 'background: white; color: #4A6B6E; border: 1px solid #E8E8E8;'}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- PRODUCT GRID SECTION -->
  <section class="py-12 md:py-16" style="background: linear-gradient(180deg, #FAFAF9 0%, #FFF5F8 100%);">
    <div class="grid-container">
      <!-- Results Header -->
      <div class="results-header flex items-center justify-between mb-8">
        <p class="font-body text-sm" style="color: #6B8A8C;">
          Hiển thị <span id="product-count" class="font-semibold" style="color: #2C3E3F;">{products.length}</span> sản phẩm
        </p>
        <div class="hidden md:flex items-center gap-2 px-4 py-2 rounded-full" style="background: linear-gradient(135deg, rgba(249,178,215,0.15) 0%, rgba(207,236,243,0.15) 100%);">
          <span class="w-2 h-2 rounded-full" style="background: #E8487A;"></span>
          <span class="font-body text-sm" style="color: #4A6B6E;">Giá: Liên hệ</span>
        </div>
      </div>

      <!-- Product Grid -->
      <div id="product-grid" class="product-grid">
        {products.map((product, index) => (
          <div 
            class="product-item rounded-3xl overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl cursor-pointer"
            data-category={product.category}
            style={`background: white; box-shadow: 0 4px 20px rgba(0,0,0,0.06);`}
          >
            <!-- Image Area -->
            <div class="relative overflow-hidden" style={`aspect-ratio: 4/5; background: linear-gradient(135deg, ${product.color || bgColors[index % 4]} 0%, ${bgColors[(index + 1) % 4]} 100%);`}>
              {product.image ? (
                <img 
                  src={product.image}
                  alt={product.name}
                  class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center p-6">
                  <span class="text-5xl mb-3 opacity-60">🌸</span>
                  <span class="font-heading italic text-center px-4" style="font-size: 0.9rem; color: #2C3E3F;">
                    {product.name}
                  </span>
                </div>
              )}

              {/* Badge */}
              {product.badge && (
                <div class="absolute top-3 left-3">
                  <span class="inline-block px-3 py-1.5 rounded-full font-body text-xs font-bold uppercase tracking-wider" style="background: linear-gradient(135deg, #F9B2D7 0%, #E8487A 100%); color: white; box-shadow: 0 2px 10px rgba(232,72,122,0.3);">
                    {product.badge}
                  </span>
                </div>
              )}
            </div>

            <!-- Content Area -->
            <div class="p-4">
              <!-- Product Name -->
              <h3 class="font-heading font-[500] leading-tight mb-2 line-clamp-2" style="font-size: 1.2rem; color: #2C3E3F; font-style: italic;">
                {product.name}
              </h3>

              <!-- Price Placeholder -->
              <div class="mt-4 pt-3" style="border-top: 1px dashed rgba(0,0,0,0.1);">
                <div class="flex items-center justify-between">
                  <span class="font-heading text-sm font-semibold" style="color: #E8487A; font-style: italic;">
                    Liên hệ báo giá
                  </span>
                  <span class="w-6 h-6 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, #CFECF3 0%, #DAF9DE 100%);">
                    <svg class="w-3 h-3" style="color: #3D7A7F;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="hidden text-center py-20">
        <div class="text-6xl mb-4">🌸</div>
        <h3 class="font-heading font-[500] text-xl mb-2" style="color: #2C3E3F; font-style: italic;">
          Không tìm thấy sản phẩm
        </h3>
        <p class="font-body text-sm" style="color: #6B8A8C;">
          Hãy thử chọn danh mục khác nhé!
        </p>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="py-16" style="background: linear-gradient(135deg, #F9B2D7 0%, #CFECF3 100%);">
    <div class="container-base text-center">
      <div class="max-w-xl mx-auto">
        <span class="text-4xl mb-4 block">💝</span>
        <h2 class="font-heading font-[500] text-2xl mb-3" style="color: #2C3E3F; font-style: italic;">
          Bạn cần hỗ trợ?
        </h2>
        <p class="font-body text-base mb-6" style="color: #4A6B6E;">
          Liên hệ với chúng tôi để được tư vấn về sản phẩm, đặt hàng theo yêu cầu hoặc báo giá nhanh nhất!
        </p>
        <!-- Social Contact Buttons -->
        <div class="flex items-center justify-center gap-4">
          <!-- Zalo Button -->
          <a href="https://zalo.me/0834748819" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-6 py-4 rounded-full bg-white transition-transform duration-300 hover:scale-105" style="box-shadow: 0 4px 20px rgba(0,0,0,0.1);">
            <img src="/tiemlennhadev/images/Logo-Zalo.png" alt="Zalo" class="w-7 h-7 object-contain" />
            <span class="font-body text-base font-semibold" style="color: #0068FF;">Zalo</span>
          </a>
          
          <!-- Facebook Button -->
          <a href="https://www.facebook.com/share/1GbuH8dXfi/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-6 py-4 rounded-full bg-white transition-transform duration-300 hover:scale-105" style="box-shadow: 0 4px 20px rgba(0,0,0,0.1);">
            <img src="/tiemlennhadev/images/facebook-logo.jpg" alt="Facebook" class="w-7 h-7 object-contain" />
            <span class="font-body text-base font-semibold" style="color: #1877F2;">Facebook</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const categoryBtns = document.querySelectorAll('.category-btn');
  const productItems = document.querySelectorAll('.product-item');
  const productCount = document.getElementById('product-count');
  const emptyState = document.getElementById('empty-state');

  categoryBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      // Update active button
      categoryBtns.forEach((b) => {
        b.style.background = 'white';
        b.style.color = '#4A6B6E';
        b.style.border = '1px solid #E8E8E8';
        b.style.boxShadow = 'none';
      });
      
      const activeBtn = btn as HTMLElement;
      if (btn.getAttribute('data-category') === 'all') {
        activeBtn.style.background = 'linear-gradient(135deg, #F9B2D7 0%, #E8487A 100%)';
        activeBtn.style.color = 'white';
        activeBtn.style.boxShadow = '0 4px 15px rgba(249,178,215,0.4)';
      } else {
        activeBtn.style.background = 'linear-gradient(135deg, #CFECF3 0%, #DAF9DE 100%)';
        activeBtn.style.color = '#2C3E3F';
        activeBtn.style.border = 'none';
      }

      // Filter products
      const filter = btn.getAttribute('data-category');
      let visibleCount = 0;

      productItems.forEach((item) => {
        const category = (item as HTMLElement).dataset.category;
        const shouldShow = filter === 'all' || category === filter;
        
        if (shouldShow) {
          (item as HTMLElement).style.display = '';
          (item as HTMLElement).style.animation = 'fadeInUp 0.4s ease forwards';
          visibleCount++;
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });

      if (productCount) productCount.textContent = String(visibleCount);
      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
      }
    });
  });

  // Add animation keyframes
  const style = document.createElement('style');
  style.textContent = `
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  `;
  document.head.appendChild(style);
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-item {
    animation: fadeInUp 0.5s ease forwards;
  }

  .filter-container {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 40px;
    padding-right: 40px;
  }

  .grid-container {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 40px;
    padding-right: 40px;
  }

  .results-header {
    max-width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  @media (max-width: 1023px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 767px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .filter-container,
    .grid-container {
      padding-left: 20px;
      padding-right: 20px;
    }
  }

  @media (max-width: 479px) {
    .product-grid {
      grid-template-columns: repeat(1, 1fr);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
