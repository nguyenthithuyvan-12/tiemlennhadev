---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  tags: string[];
  readingTime: number;
  thumbnail?: string;
}

const { title, description, pubDate, author, tags, readingTime, thumbnail } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={title} description={description}>
  <div class="blog-layout">
    <!-- POST HEADER -->
    <header class="blog-header">
      <div class="blog-header__inner">
        <!-- Tags -->
        <div class="flex flex-wrap gap-2 justify-center mb-5">
          {tags.slice(0, 3).map((tag) => (
            <span 
              class="inline-block font-body text-[0.7rem] uppercase tracking-[0.1em] px-4 py-1.5 rounded-full"
              style="background: linear-gradient(135deg, #F6FFDC 0%, #DAF9DE 100%); color: #2C3E3F;"
            >
              {tag}
            </span>
          ))}
        </div>

        <!-- Title -->
        <h1 
          class="font-heading font-[500] leading-[1.2] text-center"
          style="font-size: clamp(1.8rem, 4vw, 2.8rem); margin-top: 16px; color: #2C3E3F;"
        >
          {title}
        </h1>

        <!-- Meta row -->
        <div 
          class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mt-5"
          style="font-family: var(--font-body); font-size: 1rem; font-weight: 400; color: #5A7A7D;"
        >
          <span style="display: flex; align-items: center; gap: 8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F9B2D7" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span style="font-weight: 500; color: #2C3E3F;">{author}</span>
          </span>
          <span style="color: #CFECF3;">●</span>
          <span style="font-weight: 400;">{formatDate(pubDate)}</span>
          <span style="color: #CFECF3;">●</span>
          <span style="display: flex; align-items: center; gap: 8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#CFECF3" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12,6 12,12 16,14"/>
            </svg>
            {readingTime} phút đọc
          </span>
        </div>

        <!-- Decorative line -->
        <div 
          class="mx-auto mt-8" 
          style="width: 80px; height: 3px; background: linear-gradient(90deg, #F9B2D7, #CFECF3); border-radius: 2px;"
        ></div>
      </div>
    </header>

    <!-- HERO IMAGE -->
    <div class="blog-hero-image">
      <div 
        class="rounded-[1.5rem] overflow-hidden"
        style="max-width: 1000px; margin: 0 auto; box-shadow: 0 20px 60px rgba(0,0,0,0.12);"
      >
        {thumbnail ? (
          <img
            src={thumbnail}
            alt={title}
            style="width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; display: block;"
            loading="eager"
          />
        ) : (
          <div 
            class="aspect-video flex items-center justify-center"
            style="background: linear-gradient(135deg, #F9B2D7 0%, #CFECF3 50%, #DAF9DE 100%);"
          >
            <span class="font-heading italic opacity-60" style="color: #2C3E3F; font-size: 1rem;">
              (Ảnh bìa bài viết)
            </span>
          </div>
        )}
      </div>
    </div>

    <!-- MAIN CONTENT AREA -->
    <div class="blog-content-wrapper">
      <!-- LEFT: TABLE OF CONTENTS -->
      <aside class="blog-toc">
        <div class="toc-card">
          <p class="section-label">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle; margin-right: 8px;">
              <line x1="8" y1="6" x2="21" y2="6"/>
              <line x1="8" y1="12" x2="21" y2="12"/>
              <line x1="8" y1="18" x2="21" y2="18"/>
              <line x1="3" y1="6" x2="3.01" y2="6"/>
              <line x1="3" y1="12" x2="3.01" y2="12"/>
              <line x1="3" y1="18" x2="3.01" y2="18"/>
            </svg>
            Mục lục
          </p>
          <nav id="toc-nav" aria-label="Mục lục bài viết">
            <!-- Populated by JS -->
          </nav>
        </div>
      </aside>

      <!-- RIGHT: ARTICLE CONTENT -->
      <article class="blog-article">
        <slot />
      </article>
    </div>

    <!-- BACK LINK -->
    <div class="blog-back">
      <div class="container-base">
        <a
          href="/tiemlennhadev/blog"
          class="back-link"
        >
          <span class="back-link-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12,19 5,12 12,5"/>
            </svg>
          </span>
          <span>Quay lại Blog</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script lang="ts">
  function slugify(text: string): string {
    return text
      .toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^a-z0-9-]/g, '');
  }

  function initTOC() {
    const article = document.querySelector('.blog-article');
    const tocNav = document.getElementById('toc-nav');
    if (!article || !tocNav) return;

    const headings = article.querySelectorAll('h2, h3');
    const tocItems: { id: string; text: string; level: number }[] = [];

    headings.forEach((heading) => {
      const text = heading.textContent || '';
      let id = heading.id;

      if (!id) {
        id = slugify(text);
        heading.id = id;
      }

      tocItems.push({
        id,
        text,
        level: heading.tagName === 'H2' ? 2 : 3,
      });
    });

    tocItems.forEach((item) => {
      const a = document.createElement('a');
      a.href = `#${item.id}`;
      a.textContent = item.text;
      a.dataset.id = item.id;

      if (item.level === 2) {
        a.className = 'toc-link';
        a.style.cssText = 'display: flex; align-items: center; gap: 8px; padding: 10px 14px; font-size: 0.9rem; color: #2C3E3F; text-decoration: none; transition: all 250ms ease; border-radius: 10px; font-weight: 400;';
      } else {
        a.className = 'toc-link toc-link--sub';
        a.style.cssText = 'display: flex; align-items: center; gap: 8px; padding: 8px 14px 8px 28px; font-size: 0.85rem; color: #5A7A7D; text-decoration: none; transition: all 250ms ease; border-radius: 10px; font-weight: 400;';
      }

      tocNav.appendChild(a);
    });

    // Scroll spy with IntersectionObserver
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocNav.querySelectorAll('.toc-link').forEach((link) => {
              const isActive = (link as HTMLElement).dataset.id === id;
              if (isActive) {
                (link as HTMLElement).style.background = 'linear-gradient(135deg, #F6FFDC 0%, #DAF9DE 100%)';
                (link as HTMLElement).style.color = '#2C3E3F';
                (link as HTMLElement).style.fontWeight = '500';
              } else {
                (link as HTMLElement).style.background = 'transparent';
                (link as HTMLElement).style.color = link.classList.contains('toc-link--sub') ? '#5A7A7D' : '#2C3E3F';
                (link as HTMLElement).style.fontWeight = '400';
              }
            });
          }
        });
      },
      {
        rootMargin: '-100px 0px -60% 0px',
        threshold: 0,
      }
    );

    headings.forEach((heading) => observer.observe(heading));
  }

  initTOC();
</script>

<style>
  .blog-layout {
    background-color: #FAFAFA;
  }

  .blog-header {
    background: linear-gradient(180deg, #FFFFFF 0%, #F9F9F9 100%);
    padding: 80px 24px 48px;
  }

  .blog-header__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .blog-hero-image {
    padding: 0 24px;
    margin-top: -20px;
  }

  .blog-content-wrapper {
    display: flex;
    gap: 60px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 24px;
  }

  .blog-toc {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 100px;
    align-self: flex-start;
  }

  .toc-card {
    background: white;
    border-radius: 1.25rem;
    padding: 24px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    border: 1px solid rgba(207, 236, 243, 0.5);
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: #2C3E3F;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 2px solid #DAF9DE;
  }

  /* TOC link hover effects */
  :global(.toc-link:hover) {
    background: linear-gradient(135deg, rgba(249,178,215,0.15) 0%, rgba(207,236,243,0.15) 100%) !important;
    transform: translateX(4px);
  }

  .blog-back {
    padding: 48px 24px 80px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: #2C3E3F;
    text-decoration: none;
    padding: 14px 24px;
    background: white;
    border-radius: 50px;
    border: 2px solid #DAF9DE;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    transition: all 250ms ease;
  }

  .back-link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, #F9B2D7 0%, #CFECF3 100%);
    border-radius: 50%;
    color: white;
    transition: all 250ms ease;
  }

  .back-link:hover {
    color: #E8487A;
    border-color: #F9B2D7;
    box-shadow: 0 6px 24px rgba(249,178,215,0.3);
    transform: translateX(4px);
  }

  .back-link:hover .back-link-icon {
    background: linear-gradient(135deg, #E8487A 0%, #F9B2D7 100%);
    transform: rotate(-360deg);
  }

  /* Prose styles */
  .blog-article :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    margin: 48px 0 20px;
    color: #2C3E3F;
    padding-bottom: 12px;
    border-bottom: 2px solid #DAF9DE;
    scroll-margin-top: 100px;
  }

  .blog-article :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 500;
    margin: 32px 0 16px;
    color: #2C3E3F;
    scroll-margin-top: 100px;
  }

  .blog-article :global(p) {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 2;
    margin-bottom: 20px;
    color: #3D5A5C;
    text-align: justify;
  }

  .blog-article :global(strong) {
    font-weight: 600;
    color: #2C3E3F;
  }

  .blog-article :global(em) {
    font-style: italic;
    color: #E8487A;
  }

  .blog-article :global(a) {
    color: #E8487A;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 500;
  }

  .blog-article :global(ul),
  .blog-article :global(ol) {
    margin: 0 0 24px 28px;
    line-height: 2;
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 400;
  }

  .blog-article :global(li) {
    margin-bottom: 12px;
    color: #3D5A5C;
  }

  .blog-article :global(ul li::marker) {
    color: #F9B2D7;
  }

  .blog-article :global(blockquote) {
    border-left: 4px solid #F9B2D7;
    padding: 20px 24px;
    margin: 32px 0;
    background: linear-gradient(135deg, rgba(249,178,215,0.1) 0%, rgba(207,236,243,0.1) 100%);
    border-radius: 0 12px 12px 0;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.05rem;
    color: #5A7A7D;
  }

  .blog-article :global(code) {
    background: rgba(207,236,243,0.4);
    padding: 3px 8px;
    border-radius: 6px;
    font-family: monospace;
    font-size: 0.9em;
    color: #2C3E3F;
  }

  .blog-article :global(hr) {
    border: none;
    height: 2px;
    background: linear-gradient(90deg, #F9B2D7, #CFECF3, #DAF9DE);
    margin: 48px 0;
    border-radius: 2px;
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .blog-toc {
      display: none;
    }

    .blog-content-wrapper {
      padding: 40px 24px;
    }
  }

  @media (max-width: 767px) {
    .blog-header {
      padding: 50px 20px 40px;
    }

    .blog-hero-image {
      padding: 0 16px;
    }

    .blog-content-wrapper {
      padding: 32px 16px;
    }
  }
</style>
