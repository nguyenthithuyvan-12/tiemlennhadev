---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/tiemlennhadev/', label: 'Trang Chủ' },
  { href: '/tiemlennhadev/products', label: 'Sản Phẩm' },
  { href: '/tiemlennhadev/blog', label: 'Blog' },
  { href: '/tiemlennhadev/courses', label: 'Khóa Học' },
  { href: '/tiemlennhadev/charts', label: 'Thư Viện' },
];

function isActive(href: string): boolean {
  if (href === '/tiemlennhadev/') {
    return currentPath === href || currentPath === '/tiemlennhadev';
  }
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 transition-all duration-300" id="main-header" style="background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid rgba(255, 255, 255, 0.2); box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);">
  <div class="w-full max-w-[1280px] mx-auto px-4 sm:px-6 md:px-10 lg:px-16 h-[60px] md:h-[78px] flex items-center justify-between">
    <!-- Brand Logo -->
    <a href="/tiemlennhadev/" class="flex flex-col leading-none">
      <span class="font-heading text-xl sm:text-2xl md:text-3xl font-bold tracking-wide" style="color: #2C3E3F;">
        Tiệm Len
      </span>
      <span class="font-heading text-xs sm:text-sm md:text-lg font-semibold tracking-[0.15em] sm:tracking-[0.2em] uppercase mt-0.5" style="color: #D4869E;">
        Nhà Dev
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'desktop-nav-link font-body text-lg font-medium underline-hover px-4 py-2 rounded-full transition-all duration-300',
            isActive(link.href) ? 'font-bold' : ''
          ]}
          style={isActive(link.href) ? 'color: #fff; background: linear-gradient(135deg, #F9B2D7 0%, #D4869E 100%); box-shadow: 0 4px 15px rgba(212, 134, 158, 0.4);' : 'color: var(--color-text);'}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden md:flex items-center gap-6">
      <button
        id="header-search-btn"
        aria-label="Mở tìm kiếm"
        style="
          background: rgba(255, 255, 255, 0.5);
          backdrop-filter: blur(10px);
          border: 1px solid rgba(255, 255, 255, 0.6);
          border-radius: 50px;
          cursor: pointer;
          font-family: var(--font-body);
          font-size: 0.85rem;
          font-weight: 500;
          color: var(--color-text);
          letter-spacing: 0.02em;
          padding: 10px 20px;
          transition: all 0.3s ease;
          display: flex;
          align-items: center;
          gap: 8px;
          box-shadow: 0 4px 15px rgba(212, 134, 158, 0.15);
        "
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        Tìm kiếm
        <span style="
          display: inline-flex;
          align-items: center;
          justify-content: center;
          padding: 2px 8px;
          background: rgba(212, 134, 158, 0.2);
          border-radius: 20px;
          font-size: 0.7rem;
          font-weight: 600;
          color: #D4869E;
        ">/</span>
      </button>
    </div>

    <!-- Mobile Hamburger Button -->
    <button
      id="mobile-menu-btn"
      class="mobile-hamburger"
      aria-label="Mở menu"
      aria-expanded="false"
      aria-controls="mobile-menu-overlay"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu-overlay" class="mobile-overlay" aria-hidden="true">
  <nav id="mobile-menu-panel" class="mobile-panel" aria-label="Menu điều hướng">
    <!-- Nav links -->
    <ul id="mobile-nav-list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="mobile-nav-link">{link.label}</a>
        </li>
      ))}
    </ul>

    <!-- Divider -->
    <div class="mobile-divider"></div>

    <!-- Bottom actions -->
    <div id="mobile-menu-actions">
      <a href="#" target="_blank" rel="noopener noreferrer" class="mobile-action-link">
        Liên hệ Zalo
      </a>
      <a href="#" target="_blank" rel="noopener noreferrer" class="mobile-action-link">
        Messenger
      </a>
    </div>
  </nav>
</div>

<style>
  /* ========================================
     HAMBURGER BUTTON - Only visible on mobile
     ======================================== */
  .mobile-hamburger {
    display: none;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transform-origin: center;
    transition:
      transform 300ms ease,
      opacity 300ms ease;
  }

  /* Animated X state when menu is open */
  .mobile-hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mobile-hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .mobile-hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ========================================
     MOBILE OVERLAY - Full screen backdrop
     ======================================== */
  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0);
    z-index: 45;
    pointer-events: none;
    opacity: 0;
    transition: opacity 300ms ease;
  }

  .mobile-overlay.is-open {
    pointer-events: auto;
    background: rgba(0, 0, 0, 0.5);
    opacity: 1;
  }

  /* ========================================
     MOBILE PANEL - Slide from right
     ======================================== */
  .mobile-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    max-width: 85vw;
    height: 100vh;
    background: #ffffff;
    box-shadow: -4px 0 20px rgba(0, 0, 0, 0.15);
    transform: translateX(100%);
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 50;
    overflow-y: auto;
    padding-top: 0;
  }

  .mobile-overlay.is-open .mobile-panel {
    transform: translateX(0);
  }

  /* Mobile nav list */
  #mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Mobile nav links - SOLID, READABLE */
  .mobile-nav-link {
    display: flex;
    align-items: center;
    padding: 16px 24px;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-style: italic;
    color: #2C3E3F;
    text-decoration: none;
    border-bottom: 1px solid #e5e5e5;
    transition: all 0.3s ease;
    background: #ffffff;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.is-active {
    background: linear-gradient(135deg, #F9B2D7 0%, #D4869E 100%);
    color: #ffffff;
    font-weight: 600;
    padding-left: 28px;
  }

  .mobile-divider {
    height: 1px;
    background: #e5e5e5;
    margin: 0;
  }

  #mobile-menu-actions {
    display: flex;
    gap: 12px;
    padding: 16px 24px;
    background: #ffffff;
  }

  .mobile-action-link {
    flex: 1;
    text-align: center;
    padding: 12px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: #D4869E;
    border: 2px solid #D4869E;
    border-radius: 8px;
    text-decoration: none;
    transition: all 200ms ease;
    background: #ffffff;
  }

  .mobile-action-link:hover {
    background: #D4869E;
    color: #ffffff;
  }

  /* ========================================
     MOBILE STYLES - @media only
     ======================================== */
  @media (max-width: 768px) {
    /* Hamburger button - SOLID, VISIBLE */
    .mobile-hamburger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      width: 44px;
      height: 44px;
      padding: 10px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      background: #D4869E;
      box-shadow: 0 2px 8px rgba(212, 134, 158, 0.4);
      transition: all 0.2s ease;
      z-index: 200;
      position: relative;
    }

    .mobile-hamburger:hover {
      background: #c4788f;
      transform: scale(1.05);
    }

    .mobile-hamburger:active {
      transform: scale(0.95);
    }

    /* Hamburger lines - WHITE on pink background */
    .hamburger-line {
      background: #ffffff;
    }

    /* Active state - X animation */
    .mobile-hamburger[aria-expanded="true"] {
      background: #2C3E3F;
    }

    /* Menu overlay - HIGH z-index on mobile */
    .mobile-overlay {
      z-index: 150;
    }

    /* Menu panel - HIGH z-index on mobile */
    .mobile-panel {
      z-index: 200;
      border-left: 1px solid #e5e5e5;
    }
  }

  /* ========================================
     DESKTOP NAV LINKS - UNTOUCHED
     ======================================== */
  .desktop-nav-link {
    position: relative;
    padding: 9px 18px;
    border-radius: 999px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .desktop-nav-link:hover,
  .desktop-nav-link.active {
    background: linear-gradient(135deg, #F9B2D7 0%, #D4869E 100%);
    color: #ffffff !important;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 134, 158, 0.35);
  }
</style>

<script>
  // ========================================
  // MOBILE MENU LOGIC
  // ========================================
  const menuBtn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('mobile-menu-overlay');
  const panel = document.getElementById('mobile-menu-panel');
  const navLinks = document.querySelectorAll('.mobile-nav-link');

  let isMenuOpen = false;

  function openMenu() {
    isMenuOpen = true;
    overlay?.classList.add('is-open');
    overlay?.setAttribute('aria-hidden', 'false');
    menuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    isMenuOpen = false;
    overlay?.classList.remove('is-open');
    overlay?.setAttribute('aria-hidden', 'true');
    menuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  function toggleMenu() {
    isMenuOpen ? closeMenu() : openMenu();
  }

  // Toggle menu on button click
  menuBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleMenu();
  });

  // Close menu when clicking on overlay (outside panel)
  overlay?.addEventListener('click', (e) => {
    // Only close if clicking directly on overlay, not panel
    if (e.target === overlay) {
      closeMenu();
    }
  });

  // Close menu when clicking nav links
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });

  // Close menu when pressing Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isMenuOpen) {
      closeMenu();
      menuBtn?.focus(); // Return focus to hamburger button
    }
  });

  // Close menu when window resizes to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768 && isMenuOpen) {
      closeMenu();
    }
  });

  // ========================================
  // SCROLL SHADOW
  // ========================================
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-soft');
    } else {
      header?.classList.remove('shadow-soft');
    }
  });

  // ========================================
  // ACTIVE LINK DETECTION
  // ========================================
  function isHomePage(path: string): boolean {
    return path === '/' || path === '/tiemlennhadev' || path === '/tiemlennhadev/' || path === '' || path === '/tiemlennhadev/index';
  }

  const currentPath = window.location.pathname;
  const allNavLinks = document.querySelectorAll('.desktop-nav-link, .mobile-nav-link');

  allNavLinks.forEach(link => {
    const href = link.getAttribute('href') || '';

    if (isHomePage(href)) {
      if (isHomePage(currentPath)) {
        link.classList.add('active', 'is-active');
      }
    } else {
      if (currentPath.startsWith(href)) {
        link.classList.add('active', 'is-active');
      }
    }
  });

  // ========================================
  // SEARCH TRIGGER
  // ========================================
  const searchBtn = document.getElementById('header-search-btn');
  if (searchBtn) {
    searchBtn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('open-search'));
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
      e.preventDefault();
      window.dispatchEvent(new CustomEvent('open-search'));
    }
  });
</script>
