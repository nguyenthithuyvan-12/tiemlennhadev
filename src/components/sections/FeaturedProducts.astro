---
interface FeaturedProduct {
  id: string;
  name: string;
  category: string;
  price: number;
  badge: string | null;
  image?: string;
}

const featuredProducts: FeaturedProduct[] = [
  { id: '1', name: 'Hoa Mẫu Đơn Len', category: 'Hoa', price: 85000, badge: 'Bán chạy', image: 'hoa-maudon1.jpg' },
  { id: '2', name: 'Thú Thỏ Miffy', category: 'Thú bông', price: 45000, badge: null, image: 'tho-miffy.jpg' },
  { id: '3', name: 'Thỏ Bông Mini', category: 'Thú bông', price: 120000, badge: 'Mới', image: 'thu-bongmini-3.jpg' },
  { id: '4', name: 'Bó Hoa Len Hỗn Hợp', category: 'Hoa', price: 250000, badge: null, image: 'Bo-hoalenhh1.jpg' },
];

function formatPrice(price: number): string {
  return price.toLocaleString('vi-VN') + '₫';
}
---

<section class="py-[60px] md:py-[100px]" style="background: linear-gradient(180deg, #FFFFFF 0%, #F6FFDC 100%);">
  <div class="w-full max-w-[1280px] mx-auto px-6 md:px-10 lg:px-16">
    <!-- Section Header -->
    <div class="text-center mb-14">
      <div>
        <!-- Label với decorative -->
        <div class="flex items-center justify-center gap-3 mb-4">
          <span class="block w-8 h-[2px]" style="background: linear-gradient(90deg, #D4869E, #F9B2D7);"></span>
          <span class="font-body text-sm md:text-base tracking-[0.2em] uppercase" style="color: #D4869E; font-weight: 500;">
            ✦ Sản phẩm nổi bật ✦
          </span>
          <span class="block w-8 h-[2px]" style="background: linear-gradient(90deg, #F9B2D7, #D4869E);"></span>
        </div>
        
        <!-- Heading - Font dễ thương -->
        <h2 class="font-heading font-[500] italic leading-[1.3]" style="font-size: clamp(2rem, 4vw, 3rem); color: var(--color-text);">
          <span style="color: #D4869E;">Được làm bằng tay,</span><br>
          <span class="relative inline-block pl-[3em]">
            trao đi bằng tâm
            <span class="absolute -bottom-1 left-[3em] w-[calc(100%-3em)] h-[3px] rounded-full" style="background: linear-gradient(90deg, #D4869E, #F9B2D7, #8BC34A);"></span>
          </span>
        </h2>
      </div>
      <a
        href="/tiemlennhadev/products"
        class="hidden md:inline-flex items-center gap-2 font-body text-[0.9rem] font-medium mt-6 px-5 py-2.5 rounded-full transition-all duration-300 hover:scale-105"
        style="background: linear-gradient(135deg, #F9B2D7 0%, #D4869E 100%); color: #fff; box-shadow: 0 4px 15px rgba(212,134,158,0.35);"
      >
        Xem tất cả sản phẩm
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Product Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {featuredProducts.map((product, index) => {
        const isOffsetCard = index === 0 || index === 2;
        const isPrimaryBg = index === 0 || index === 2;
        return (
          <article class:list={['group relative overflow-hidden rounded-2xl transition-all duration-300 hover:-translate-y-2 hover:shadow-xl', isOffsetCard && 'md:mt-8']} style={`background-color: white; box-shadow: 0 4px 20px rgba(0,0,0,0.08);`}>
            {/* Image Area */}
            <div class="relative overflow-hidden" style={`aspect-ratio: 1/1; background-color: ${isPrimaryBg ? '#F9F0F5' : '#F0F9F1'};`}>
              {product.image ? (
                <img 
                  src={`/tiemlennhadev/images/${product.image}`}
                  alt={product.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <span class="absolute inset-0 flex items-center justify-center font-heading italic text-lg opacity-40" style="color: #3D7A7F;">
                  {product.category}
                </span>
              )}

              {/* Badge */}
              {product.badge && (
                <span
                  class="absolute top-3 right-3 text-[0.65rem] uppercase tracking-[0.1em] px-3 py-1.5 z-10 font-medium"
                  style="background-color: #D4869E; color: #fff; border-radius: 20px; box-shadow: 0 2px 8px rgba(212,134,158,0.4);"
                >
                  {product.badge}
                </span>
              )}

              {/* Hover Overlay */}
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>

            {/* Content Area */}
            <div class="p-5 text-center">
              <span class="block text-[0.7rem] uppercase tracking-[0.2em] font-medium" style="color: #D4869E;">
                {product.category}
              </span>
              <h3 class="font-heading text-[1.05rem] font-[500] mt-2 mb-3" style="color: #2C3E3F;">
                {product.name}
              </h3>
              
              {/* Price/Contact */}
              <div class="flex items-center justify-center gap-2">
                <span 
                  class="inline-flex items-center px-4 py-2 text-[0.85rem] font-medium rounded-full transition-all duration-300 hover:scale-105 cursor-pointer"
                  style="background: linear-gradient(135deg, #CFECF3 0%, #DAF9DE 100%); color: #2C3E3F; box-shadow: 0 2px 10px rgba(61,122,127,0.15);"
                >
                  Liên hệ
                </span>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <!-- Mobile: View All Link -->
    <div class="md:hidden mt-8 text-center">
      <a
        href="/tiemlennhadev/products"
        class="inline-flex items-center gap-2 font-body text-[0.9rem] font-medium px-5 py-2.5 rounded-full transition-all duration-300 hover:scale-105"
        style="background: linear-gradient(135deg, #F9B2D7 0%, #D4869E 100%); color: #fff; box-shadow: 0 4px 15px rgba(212,134,158,0.35);"
      >
        Xem tất cả sản phẩm
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

