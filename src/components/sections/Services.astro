---
const services = [
  {
    icon: 'gift',
    title: 'Quà tặng ý nghĩa',
    description: 'Những món quà được làm thủ công với tình yêu và sự tỉ mỉ, mang đến niềm vui cho người nhận.',
  },
  {
    icon: 'heart',
    title: 'Sản phẩm handmade',
    description: '100% tự làm, độc đáo và riêng biệt. Mỗi sản phẩm đều mang đậm cá tính của người tạo ra.',
  },
  {
    icon: 'truck',
    title: 'Giao hàng tận nơi',
    description: 'Đóng gói cẩn thận, giao hàng nhanh chóng trên toàn quốc. Theo dõi đơn hàng dễ dàng.',
  },
  {
    icon: 'support',
    title: 'Hỗ trợ 24/7',
    description: 'Đội ngũ tư vấn nhiệt tình, sẵn sàng giải đáp mọi thắc mắc của khách hàng.',
  },
];
---

<section class="py-[60px] md:py-[100px]" style="background: linear-gradient(180deg, #FFFFFF 0%, #F6FFDC 100%);">
  <div class="w-full max-w-[1280px] mx-auto px-6 md:px-10 lg:px-16">
    <!-- Section Header -->
    <div class="text-center mb-14">
      <!-- Label với decorative -->
      <div class="flex items-center justify-center gap-3 mb-3">
        <span class="block w-8 h-[2px]" style="background: linear-gradient(90deg, #D4869E, #F9B2D7);"></span>
        <span class="font-body text-lg md:text-xl tracking-[0.2em] uppercase font-bold" style="color: #D4869E;">
          ✦ Dịch vụ ✦
        </span>
        <span class="block w-8 h-[2px]" style="background: linear-gradient(90deg, #F9B2D7, #D4869E);"></span>
      </div>
      <h2 class="font-heading font-bold italic leading-[1.3]" style="font-size: clamp(2rem, 3.5vw, 2.8rem); color: #2C3E3F;">
        Dịch vụ của Tiệm Len Nhà Dev.
      </h2>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service, index) => (
        <div
          class="p-8 rounded-[var(--radius-md)] text-center transition-all duration-300 hover:scale-105 hover:shadow-lg group"
          style="background: white; border: 2px solid #DAF9DE;"
        >
          <!-- Icon -->
          <div class="w-16 h-16 mx-auto mb-5 rounded-full flex items-center justify-center transition-colors duration-300" style="background: linear-gradient(135deg, #DAF9DE, #CFECF3);">
            {service.icon === 'gift' && (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="#D4869E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 12 20 22 4 22 4 12"></polyline>
                <rect x="2" y="7" width="20" height="5"></rect>
                <line x1="12" y1="22" x2="12" y2="7"></line>
                <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
              </svg>
            )}
            {service.icon === 'heart' && (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="#D4869E" stroke="#D4869E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
            )}
            {service.icon === 'truck' && (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="#D4869E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
            )}
            {service.icon === 'support' && (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="#D4869E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
            )}
          </div>

          <!-- Title -->
          <h3 class="font-heading text-lg md:text-xl font-bold italic mb-3" style="color: #2C3E3F;">
            {service.title}
          </h3>

          <!-- Description -->
          <p class="font-body text-sm md:text-base leading-relaxed font-medium" style="color: #3D7A7F;">
            {service.description}
          </p>

          <!-- Decorative dot -->
          <div class="mt-5 flex justify-center gap-2">
            <span class="w-2 h-2 rounded-full transition-colors duration-300" style="background-color: #DAF9DE;"></span>
            <span class="w-2 h-2 rounded-full transition-colors duration-300" style="background-color: #CFECF3;"></span>
            <span class="w-2 h-2 rounded-full transition-colors duration-300" style="background-color: #F9B2D7;"></span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
