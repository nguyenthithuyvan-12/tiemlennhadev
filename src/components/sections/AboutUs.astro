---
---

<section id="about" class="py-[70px] md:py-[120px]" style="background-color: var(--color-background);">
  <div class="w-full max-w-[1280px] mx-auto px-6 md:px-10 lg:px-16">
    <div class="grid grid-cols-1 md:grid-cols-[45%_55%] gap-10 md:gap-16 items-center">
      <!-- Left Column: Visual -->
      <div class="order-2 md:order-1">
        <!-- Main Image -->
        <img
          src="/tiemlennhadev/images/hoahonhop.jpg"
          alt="Hoa hồng handmade từ len"
          class="w-full rounded-[var(--radius-md)] object-contain"
          loading="lazy"
        />

        <!-- Secondary Detail Strip -->
        <div
          class="h-20 rounded-[var(--radius-md)] flex items-center justify-center mt-4"
          style="background-color: var(--color-primary);"
        >
          <span class="font-heading italic text-[0.9rem]" style="color: var(--color-primary-dark);">
            Handmade since 2022
          </span>
        </div>
      </div>

      <!-- Right Column: Text -->
      <div class="order-1 md:order-2">
        <!-- Label với decorative -->
        <div class="flex items-center gap-3 mb-3">
          <span class="block w-6 h-[2px]" style="background: linear-gradient(90deg, #D4869E, #F9B2D7);"></span>
          <span class="font-body text-sm tracking-[0.15em] uppercase" style="color: #D4869E;">
            Câu chuyện của chúng tôi
          </span>
        </div>

        <h2 class="font-heading font-[500] italic leading-[1.4]" style="font-size: clamp(1.8rem, 3vw, 2.6rem); color: #2C3E3F;">
          Mỗi sợi len là một lần<br>
          <span style="color: #D4869E;">chúng tôi gửi gắm tâm ý.</span>
        </h2>

        <p class="font-body text-base md:text-[1.05rem] leading-[1.85] mt-5" style="color: #3D7A7F;">
          Tiệm Len Nhà Dev bắt đầu từ một góc nhỏ, đôi bàn tay, và tình yêu với từng mũi móc. Chúng tôi không sản xuất hàng loạt — mỗi sản phẩm được làm thủ công, kiểm tra kỹ lưỡng trước khi đến tay bạn.
        </p>

        <p class="font-body text-base md:text-[1.05rem] leading-[1.85] mt-4" style="color: #6B8A8C;">
          Chúng tôi dùng sợi len chất lượng, an toàn — không tẩy màu hóa học. Màu sắc bền, xúc cảm thật.
        </p>

        <!-- Divider -->
        <div class="flex items-center gap-3 my-6">
          <span class="block w-10 h-px" style="background-color: #D4869E;"></span>
          <span class="block w-2 h-2 rounded-full" style="background-color: #F9B2D7;"></span>
          <span class="block w-10 h-px" style="background-color: #D4869E;"></span>
        </div>

        <!-- Value Points -->
        <div class="flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <span class="mt-1 text-lg" style="color: #D4869E;">♡</span>
            <div>
              <h4 class="font-heading italic text-[1.1rem] mb-1" style="color: #2C3E3F;">Handmade hoàn toàn</h4>
              <p class="font-body text-[0.95rem]" style="color: #6B8A8C;">Không dùng máy móc. Từng mũi len là một lần tập trung.</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="mt-1 text-lg" style="color: #D4869E;">♡</span>
            <div>
              <h4 class="font-heading italic text-[1.1rem] mb-1" style="color: #2C3E3F;">Chất liệu an toàn</h4>
              <p class="font-body text-[0.95rem]" style="color: #6B8A8C;">Sợi len mềm, không gây dị ứng, phù hợp làm quà tặng cho trẻ em.</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="mt-1 text-lg" style="color: #D4869E;">♡</span>
            <div>
              <h4 class="font-heading italic text-[1.1rem] mb-1" style="color: #2C3E3F;">Đặt theo yêu cầu</h4>
              <p class="font-body text-[0.95rem]" style="color: #6B8A8C;">Bạn muốn màu riêng, kích thước riêng? Chúng tôi làm được.</p>
            </div>
          </div>
        </div>

        <a href="/tiemlennhadev/products" class="btn-primary inline-block mt-8">Xem Sản Phẩm</a>
      </div>
    </div>
  </div>
</section>
