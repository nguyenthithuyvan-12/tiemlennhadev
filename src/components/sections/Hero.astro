---
---

<section class="relative min-h-[calc(100vh-60px)] md:min-h-[calc(100vh-72px)] overflow-hidden" style="background: linear-gradient(135deg, #CFECF3 0%, #F6FFDC 50%, #F9B2D7 100%);">
  <!-- Decorative circles -->
  <div class="absolute w-[500px] h-[500px] rounded-full pointer-events-none" style="background-color: #F9B2D7; opacity: 0.2; top: -150px; right: -150px; z-index: 0;"></div>
  <div class="absolute w-[300px] h-[300px] rounded-full pointer-events-none" style="background-color: #DAF9DE; opacity: 0.3; bottom: -100px; left: -100px; z-index: 0;"></div>

  <div class="w-full max-w-[1280px] mx-auto px-4 sm:px-6 md:px-10 lg:px-16 relative z-[1]">
    <div class="grid grid-cols-1 md:grid-cols-[55%_45%] items-center min-h-[calc(100vh-60px)] md:min-h-[calc(100vh-72px)] py-10 md:py-0">
      <!-- Left Column: Text Content -->
      <div class="order-2 md:order-1">
        <!-- Label -->
        <div class="flex items-center gap-4 mb-8">
          <span class="block w-10 h-px" style="background-color: #D4869E;"></span>
          <div class="flex items-center gap-2 text-base md:text-lg tracking-[0.15em] uppercase">
            <span style="color: #D4869E;">Handmade</span>
            <span style="color: #6BA3A8;">·</span>
            <span style="color: #8BC34A;">Len tự nhiên</span>
            <span style="color: #6BA3A8;">·</span>
            <span style="color: #C62828; font-weight: 600;">Việt Nam</span>
          </div>
        </div>

        <!-- Heading -->
        <h1 class="font-heading text-[clamp(2rem,8vw,2.8rem)] md:text-[clamp(2.8rem,5vw,4.5rem)] font-[500] leading-[1.1]" style="color: #2C3E3F;">
          Từng mũi len,<br>
          một <em class="not-italic" style="color: #D4869E;">tình yêu</em>.
        </h1>

        <!-- Sub-paragraph -->
        <p class="font-body text-base md:text-[1.05rem] font-normal leading-[1.85] max-w-[460px] mt-6" style="color: #2C3E3F;">
          Tiệm Len Nhà Dev mang đến những sản phẩm len handmade được làm thủ công tỉ mỉ — từ hoa len, móc khóa đến thú bông. Mỗi sản phẩm là một tác phẩm.
        </p>

        <!-- CTA Buttons - Glassmorphism + Dynamic Island Style -->
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 mt-10">
          <a 
            href="/tiemlennhadev/products" 
            class="relative group px-6 sm:px-8 py-3 sm:py-3.5 rounded-full font-body text-sm sm:text-base font-medium overflow-hidden text-center transition-all duration-300 hover:scale-105 hover:shadow-xl w-auto sm:w-auto"
            style="background: linear-gradient(135deg, #D4869E 0%, #F9B2D7 100%); color: white; box-shadow: 0 4px 15px rgba(212, 134, 158, 0.4), inset 0 1px 0 rgba(255,255,255,0.2);"
          >
            <span class="relative z-10">Xem Sản Phẩm</span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent opacity-0 group-hover:opacity-100 group-hover:animate-shimmer transition-opacity duration-500"></div>
          </a>
          
          <a 
            href="#about" 
            class="relative group px-6 sm:px-8 py-3 sm:py-3.5 rounded-full font-body text-sm sm:text-base font-medium text-center transition-all duration-300 hover:scale-105 w-auto sm:w-auto"
            style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); color: #2C3E3F; border: 1px solid rgba(255,255,255,0.5); box-shadow: 0 4px 15px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.8);"
          >
            <span class="relative z-10">Về Chúng Tôi</span>
            <div class="absolute inset-0 rounded-full bg-gradient-to-r from-transparent via-white/30 to-transparent opacity-0 group-hover:opacity-100 group-hover:animate-shimmer transition-opacity duration-500"></div>
          </a>
        </div>

        <!-- Stats Row - Clean Modern Pills -->
        <div class="stats-row flex flex-nowrap items-center gap-2 sm:gap-4 mt-12 overflow-x-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
          <div class="stat-pill flex-shrink-0">
            <span class="stat-number">200+</span>
            <span class="stat-text">Sản phẩm</span>
          </div>
          <div class="stat-divider flex-shrink-0"></div>
          <div class="stat-pill flex-shrink-0">
            <span class="stat-number">500+</span>
            <span class="stat-text">Khách hàng</span>
          </div>
          <div class="stat-divider flex-shrink-0"></div>
          <div class="stat-pill flex-shrink-0">
            <span class="stat-number">3+</span>
            <span class="stat-text">Năm kinh nghiệm</span>
          </div>
        </div>
      </div>

      <!-- Right Column: Image Area -->
      <div class="order-1 md:order-2 relative md:mt-[-40px]">
        <div class="relative animate-float">
          <img
            src="/tiemlennhadev/images/anh-bia.png"
            alt="Sản phẩm len handmade"
            class="w-full aspect-[4/5] rounded-[var(--radius-lg)] object-cover shadow-card"
            loading="eager"
          />

          <!-- Pink accent badge - Dynamic Island Style -->
          <div class="absolute -top-3 -right-3 px-5 py-2.5 rounded-full shadow-xl overflow-hidden" style="background: linear-gradient(135deg, #D4869E, #F9B2D7);">
            <span class="relative z-10 font-body text-sm font-semibold" style="color: white;">NEW</span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent animate-shimmer"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Stat Pill - Clean Modern Style */
  .stat-pill {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding: 12px 20px;
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(212, 134, 158, 0.25);
    box-shadow: 
      0 2px 12px rgba(0, 0, 0, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    transition: all 0.3s ease;
  }

  .stat-pill:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(212, 134, 158, 0.4);
    box-shadow: 0 6px 20px rgba(212, 134, 158, 0.12);
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: #D4869E;
    letter-spacing: -0.02em;
  }

  .stat-text {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 400;
    color: #3D7A7F;
  }

  .stat-divider {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: linear-gradient(135deg, #D4869E, #F9B2D7);
  }

  /* Shimmer Animation */
  @keyframes shimmer {
    0% { transform: translateX(-100%) skewX(-15deg); }
    100% { transform: translateX(200%) skewX(-15deg); }
  }

  .animate-shimmer {
    animation: shimmer 2.5s ease-in-out infinite;
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .stat-pill {
      padding: 8px 12px;
    }
    .stat-number {
      font-size: 1rem;
    }
    .stat-text {
      font-size: 0.8rem;
    }
  }

  /* Hide scrollbar for stats row */
  .stats-row::-webkit-scrollbar {
    display: none;
  }
  .stats-row {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
</style>
