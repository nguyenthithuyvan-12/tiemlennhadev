---
const socialLinks = [
  {
    name: 'Facebook',
    href: 'https://www.facebook.com/share/1GbuH8dXfi/?mibextid=wwXIfr',
    icon: 'facebook',
    color: '#1877F2',
  },
  {
    name: 'Instagram',
    href: 'https://www.instagram.com/tiemlennhadev?igsh=MTl4NnBjZG5kMzIzag%3D%3D&utm_source=qr',
    icon: 'instagram',
    color: '#E4405F',
  },
  {
    name: 'Zalo',
    href: 'https://zalo.me/0834748819',
    icon: 'zalo',
    color: '#0068FF',
  },
];
---

<div class="fixed bottom-6 right-6 z-50 flex flex-col gap-3">
  {socialLinks.map((social, index) => (
    <a
      href={social.href}
      target="_blank"
      rel="noopener noreferrer"
      class="social-btn group"
      style={`animation-delay: ${index * 0.2}s;`}
      title={social.name}
    >
      <span class="social-icon-wrapper" style={`background: ${social.color};`}>
        {social.icon === 'facebook' && (
          <svg viewBox="0 0 24 24" fill="white" class="w-5 h-5">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        )}
        {social.icon === 'instagram' && (
          <svg viewBox="0 0 24 24" fill="white" class="w-5 h-5">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        )}
        {social.icon === 'threads' && (
          <svg viewBox="0 0 24 24" fill="white" class="w-5 h-5">
            <path d="M12 6.76c-.96 0-1.75-.78-1.75-1.75S11.04 3.26 12 3.26s1.75.78 1.75 1.75-.79 1.75-1.75 1.75zm-6.24 6.12c.96-1.2 2.63-1.12 3.12 0l.12-.96c.49-1.12 2.16-1.12 2.64 0l.12.96c.5-1.12 2.17-1.2 3.12 0l.96-1.68c.5-.88-.12-1.92-1.08-2.4l-.84-.36-.36-.84c-.48-.96-1.56-1.56-2.52-1.56s-2.04.6-2.52 1.56l-.36.84-.84.36c-.96.48-1.56 1.56-1.08 2.4l.96 1.68zm.12 2.12c-.96 0-1.75-.78-1.75-1.75s.79-1.75 1.75-1.75 1.75.78 1.75 1.75-.79 1.75-1.75 1.75zm9.36 2.88c-2.08 0-4.12-.76-5.6-2.08l.6-1.32c1.6 1.44 3.68 1.96 5.6 1.4.24-.08.48.08.48.36v.6c0 1.8-1.36 2.04-2.08 2.04zm.88-4.72c-.24-.08-.56 0-.6.36-.08.56-.28 1.12-.56 1.6-.56.84-1.36 1.36-2.32 1.36-.2 0-.4-.04-.6-.08l.36-1.56c.16-.08.36-.12.56-.12.6 0 1.16-.24 1.56-.72.28-.28.52-.64.64-1 .16-.64.2-1.32.08-1.96 1.16.4 1.92 1.48 1.88 2.72 0 .4-.36.4-.44.4z"/>
