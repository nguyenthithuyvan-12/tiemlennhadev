<button
  id="theme-toggle"
  aria-label="Chuyen giao dien toi/sang"
  title="Chuyen giao dien"
>
  <span id="theme-icon-light" aria-hidden="true">Sang</span>
  <span id="theme-icon-dark"  aria-hidden="true">Toi</span>
</button>

<style>
  #theme-toggle {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    padding: 6px 14px;
    transition: border-color var(--transition-base), color var(--transition-base);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  #theme-toggle:hover {
    border-color: var(--color-primary-dark);
    color: var(--color-text);
  }

  /* Show/hide correct label based on current theme */
  html:not([data-theme="dark"]) #theme-icon-dark { display: none; }
  html[data-theme="dark"] #theme-icon-light { display: none; }
</style>

<script lang="ts">
  const btn = document.getElementById('theme-toggle');
  
  function getCurrentTheme(): string {
    return document.documentElement.getAttribute('data-theme') ?? 'light';
  }

  function setTheme(theme: 'light' | 'dark'): void {
    if (theme === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    } else {
      document.documentElement.removeAttribute('data-theme');
    }
    localStorage.setItem('tiemlennhadev-theme', theme);
  }

  btn?.addEventListener('click', () => {
    const current = getCurrentTheme();
    setTheme(current === 'dark' ? 'light' : 'dark');
  });

  // Sync with OS preference changes
  window.matchMedia('(prefers-color-scheme: dark)')
    .addEventListener('change', (e) => {
      if (!localStorage.getItem('tiemlennhadev-theme')) {
        setTheme(e.matches ? 'dark' : 'light');
      }
    });
</script>
